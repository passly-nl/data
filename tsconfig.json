{
    "compilerOptions": {
        "target": "esnext",
        "lib": [
            "dom",
            "dom.iterable",
            "esnext"
        ],
        "allowJs": false,
        "skipLibCheck": true,
        "strict": false,
        "forceConsistentCasingInFileNames": true,
        "esModuleInterop": true,
        "module": "esnext",
        "moduleResolution": "bundler",
        "resolveJsonModule": false,
        "isolatedModules": true,
        "isolatedDeclarations": true,
        "jsx": "react-jsx",
        "rootDir": "src",
        "outDir": "dist",
        "declaration": true,
        "declarationDir": "dist",
        "declarationMap": true,
        "emitDeclarationOnly": true,
        "experimentalDecorators": true,
        "paths": {
            "#data/*": ["./src/*"]
        }
    },
    "include": [
        "src/**/*.ts",
        "build.ts"
    ],
    "exclude": [
        "dist",
        "node_modules"
    ]
}
