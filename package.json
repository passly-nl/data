{
    "name": "@passly-nl/data",
    "description": "API implementation for Passly.",
    "version": "0.0.0",
    "type": "module",
    "license": "MIT",
    "funding": "https://github.com/sponsors/basmilius",
    "author": {
        "name": "Bas Milius",
        "email": "bas@mili.us",
        "url": "https://bas.dev"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/basmilius/passly-data.git"
    },
    "keywords": [
        "api",
        "passly",
        "passly-nl"
    ],
    "files": [
        "dist",
        "src",
        "CODEOWNERS",
        "LICENSE"
    ],
    "publishConfig": {
        "access": "public",
        "provenance": true
    },
    "scripts": {
        "build": "tsgo --noEmit && tsdown",
        "dev": "tsdown --watch"
    },
    "main": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "typings": "./dist/index.d.mts",
    "sideEffects": false,
    "imports": {
        "#data/*": [
            "./src/*"
        ]
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        },
        "./*": "./*"
    },
    "dependencies": {
        "@basmilius/http-client": "^3.9.0",
        "@flux-ui/types": "^3.0.0-next.28",
        "@fortawesome/fontawesome-common-types": "^7.2.0",
        "apexcharts": "^5.6.0",
        "luxon": "^3.7.2"
    },
    "devDependencies": {
        "@types/luxon": "^3.7.1",
        "@typescript/native-preview": "^7.0.0-dev.20260228.1",
        "tsdown": "^0.21.0-beta.2"
    }
}
